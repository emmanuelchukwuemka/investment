# ──────────────────────────────────────────
# Render deployment env vars — copy these into
# the Render dashboard (Environment tab), NOT into a committed file.
# ──────────────────────────────────────────

APP_NAME="Zenith Edge Investment"
APP_ENV=production
APP_DEBUG=false
APP_KEY=                          # generate locally: php artisan key:generate --show
APP_URL=https://your-app.onrender.com

LOG_CHANNEL=stderr
LOG_LEVEL=error

# Neon connection — take the URI Neon gives you and change its
# "postgres://" or "postgresql://" prefix to "pgsql://", keep ?sslmode=require
DB_CONNECTION=pgsql
DB_URL=pgsql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# No shared/persistent disk on Render -> use DB-backed session/cache/queue
SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true
CACHE_STORE=database
QUEUE_CONNECTION=database

MAIL_MAILER=log                   # switch to smtp once you have a mail provider
MAIL_FROM_ADDRESS=hello@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

PAYMENT_BTC_ADDRESS=
PAYMENT_ETH_ADDRESS=
PAYMENT_USDT_TRC20_ADDRESS=
PAYMENT_USDT_ERC20_ADDRESS=
PAYMENT_BANK_NAME=
PAYMENT_BANK_ACCOUNT_NAME=
PAYMENT_BANK_ACCOUNT_NUMBER=
PAYMENT_BANK_ROUTING_NUMBER=
PAYMENT_BANK_SWIFT_CODE=
PAYMENT_BANK_COUNTRY=
